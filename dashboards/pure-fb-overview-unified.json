    {
      "id": 20,
      "type": "row",
      "title": "Top $TopItems Filesystems",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 43
      },
      "collapsed": false
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "Top $TopItems Filesystem Throughput by IO Type",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 44
      },
      "targets": [
        {
          "refId": "A",
          "expr": "topk($TopItems, sum by (instance, name, dimension) (purefb_file_systems_performance_bandwidth_bytes{instance=~\"$fb\"}))",
          "legendFormat": "OM \u00b7 {{name}} @ {{instance}} / {{dimension}}"
        },
        {
          "refId": "B",
          "expr": "topk($TopItems, sum by (device_name, entity_name, op) (flashblade_storage_device_fs_bw_bps{device_name=~\"$fb\", op=~\"read|write\"}))",
          "legendFormat": "OTel \u00b7 {{entity_name}} @ {{device_name}} / {{op}}"
