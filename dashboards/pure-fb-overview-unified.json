      "id": 11,
      "type": "timeseries",
      "title": "Read Throughput by Protocol",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 27
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (instance, protocol) (purefb_array_performance_bandwidth_bytes{instance=~\"$fb\", protocol=~\"$protocol\", dimension=\"read_bytes_per_sec\"})",
          "legendFormat": "OM \u00b7 {{instance}} / {{protocol}}"
        },
        {
          "refId": "B",
          "expr": "sum by (device_name, proto) (flashblade_storage_device_bw_bps{device_name=~\"$fb\", proto=~\"$protocol\", op=\"read\"})",
          "legendFormat": "OTel \u00b7 {{device_name}} / {{proto}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps"
        }
      }
    },
    {
