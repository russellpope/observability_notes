      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (instance, protocol) (purefb_array_performance_bandwidth_bytes{instance=~\"$fb\", protocol=~\"$protocol\", dimension=\"write_bytes_per_sec\"})",
          "legendFormat": "OM \u00b7 {{instance}} / {{protocol}}"
        },
        {
          "refId": "B",
          "expr": "sum by (device_name, proto) (flashblade_storage_device_bw_bps{device_name=~\"$fb\", proto=~\"$protocol\", op=\"write\"})",
