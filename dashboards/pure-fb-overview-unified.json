{
  "title": "Pure Storage FlashBlade - Overview (Unified)",
  "uid": "fb-overview-unified",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-3h",
    "to": "now"
  },
  "tags": [
    "pure",
    "flashblade",
    "overview",
    "unified",
    "otel"
  ],
  "templating": {
    "list": [
      {
        "name": "fb",
        "label": "FlashBlade",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "query": {
          "query": "query_result(label_replace(purefb_info, \"fb\", \"$1\", \"instance\", \"(.+)\") or label_replace(last_over_time(flashblade_storage_device_health[10m]), \"fb\", \"$1\", \"device_name\", \"(.+)\"))",
          "refId": "StandardVariableQuery"
        },
        "refresh": 1,
        "includeAll": true,
        "allValue": ".+",
        "multi": true,
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "regex": ".*fb=\"([^\"]+)\".*"
      },
      {
        "name": "protocol",
        "label": "Protocol",
        "type": "custom",
        "query": "NFS,SMB,S3,HTTP,all",
        "refresh": 1,
        "includeAll": true,
        "allValue": ".+",
        "multi": true,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "TopItems",
        "label": "Top N",
        "type": "custom",
        "query": "5,10,15,25,50",
        "current": {
          "text": "10",
          "value": "10"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "text",
      "title": "",
      "gridPos": {
        "h": 4,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "options": {
        "mode": "markdown",
        "content": "## FlashBlade Overview (Unified)\n\nCross-path view of every FB sending telemetry \u2014 **OpenMetrics proxy** (`purefb_*`) and **native OTel push** (`flashblade_storage_device_*`). Panels query both and merge where schemas align; panels that depend on one path only are labeled in the title. See `GAPS.md` for metrics that exist on one path but not the other."
      }
    },
    {
      "id": 2,
      "type": "table",
      "title": "FlashBlade Array System Detail",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 7,
        "w": 24,
        "x": 0,
        "y": 4
      },
      "targets": [
        {
          "refId": "INFO",
          "format": "table",
          "instant": true,
          "expr": "sum by (fb, os, version) (label_replace(label_replace(label_replace(label_replace(purefb_info{instance=~\"$fb\"}, \"fb\", \"$1\", \"instance\", \"(.+)\"), \"os\", \"$1\", \"os\", \"(.+)\"), \"version\", \"$1\", \"version\", \"(.+)\"), \"fb\", \"$1\", \"instance\", \"(.+)\")) or sum by (fb, os, version) (label_replace(label_replace(label_replace(last_over_time(flashblade_storage_device_info{device_name=~\"$fb\"}[10m]), \"fb\", \"$1\", \"device_name\", \"(.+)\"), \"os\", \"$1\", \"device_os\", \"(.+)\"), \"version\", \"$1\", \"device_vers\", \"(.+)\"))"
        },
        {
          "refId": "USED",
          "format": "table",
          "instant": true,
          "expr": "sum by (fb) (label_replace(purefb_array_space_bytes{space=\"total_physical\", instance=~\"$fb\"}, \"fb\", \"$1\", \"instance\", \"(.+)\")) or sum by (fb) (label_replace(last_over_time(flashblade_storage_device_space_bytes{space_type=\"total_physical\", exported_storage_type=\"all\", device_name=~\"$fb\"}[10m]), \"fb\", \"$1\", \"device_name\", \"(.+)\"))"
        },
        {
          "refId": "CAP",
          "format": "table",
          "instant": true,
          "expr": "sum by (fb) (label_replace(purefb_array_space_bytes{space=\"capacity\", instance=~\"$fb\"}, \"fb\", \"$1\", \"instance\", \"(.+)\")) or sum by (fb) (label_replace(last_over_time(flashblade_storage_device_space_bytes{space_type=\"capacity\", exported_storage_type=\"all\", device_name=~\"$fb\"}[10m]), \"fb\", \"$1\", \"device_name\", \"(.+)\"))"
        },
        {
          "refId": "DRR",
          "format": "table",
          "instant": true,
          "expr": "avg by (fb) (label_replace(purefb_array_space_data_reduction_ratio{instance=~\"$fb\"}, \"fb\", \"$1\", \"instance\", \"(.+)\")) or avg by (fb) (label_replace(last_over_time(flashblade_storage_device_space_reduction{exported_storage_type=\"all\", device_name=~\"$fb\"}[10m]), \"fb\", \"$1\", \"device_name\", \"(.+)\"))"
        },
        {
          "refId": "ALERTS",
          "format": "table",
          "instant": true,
          "expr": "count by (fb) (label_replace(purefb_alerts_open{instance=~\"$fb\"}, \"fb\", \"$1\", \"instance\", \"(.+)\")) or count by (fb) (label_replace(last_over_time(flashblade_storage_device_alerts{device_name=~\"$fb\"}[10m]), \"fb\", \"$1\", \"device_name\", \"(.+)\"))"
        },
        {
          "refId": "UNHEALTHY",
          "format": "table",
          "instant": true,
          "expr": "count by (fb) (label_replace(purefb_hardware_health{instance=~\"$fb\"} != 1, \"fb\", \"$1\", \"instance\", \"(.+)\")) or count by (fb) (label_replace(last_over_time(flashblade_storage_device_health{device_name=~\"$fb\"}[10m]) != 5, \"fb\", \"$1\", \"device_name\", \"(.+)\"))"
        }
      ],
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true
            },
            "indexByName": {
              "fb": 0,
              "os": 1,
              "version": 2,
              "Value #USED": 3,
              "Value #CAP": 4,
              "Value #DRR": 5,
              "Value #ALERTS": 6,
              "Value #UNHEALTHY": 7
            },
            "renameByName": {
              "fb": "FlashBlade",
              "os": "OS",
              "version": "Version",
              "Value #USED": "Used",
              "Value #CAP": "Capacity",
              "Value #DRR": "DRR",
              "Value #ALERTS": "Alerts",
              "Value #UNHEALTHY": "Unhealthy components"
            }
          }
        }
      ],
      "options": {
        "showHeader": true,
        "cellHeight": "sm"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "filterable": true
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Used"
            },
            "properties": [
              {
                "id": "unit",
                "value": "bytes"
              },
              {
                "id": "decimals",
                "value": 2
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Capacity"
            },
            "properties": [
              {
                "id": "unit",
                "value": "bytes"
              },
              {
                "id": "decimals",
                "value": 2
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "DRR"
            },
            "properties": [
              {
                "id": "unit",
                "value": "none"
              },
              {
                "id": "decimals",
                "value": 2
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Alerts"
            },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background"
                }
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "green",
                      "value": null
                    },
                    {
                      "color": "yellow",
                      "value": 1
                    },
                    {
                      "color": "red",
                      "value": 5
                    }
                  ]
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Unhealthy components"
            },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background"
                }
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "green",
                      "value": null
                    },
                    {
                      "color": "red",
                      "value": 1
                    }
                  ]
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": 3,
      "type": "table",
      "title": "Open Alerts",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 11
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "instant": true,
          "expr": "label_replace(purefb_alerts_open{instance=~\"$fb\"}, \"fb\", \"$1\", \"instance\", \"(.+)\")"
        },
        {
          "refId": "B",
          "format": "table",
          "instant": true,
          "expr": "label_replace(last_over_time(flashblade_storage_device_alerts{device_name=~\"$fb\"}[10m]), \"fb\", \"$1\", \"device_name\", \"(.+)\")"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "job": true,
              "namespace": true,
              "storage_type": true,
              "source": true,
              "env": true,
              "instance": true,
              "device_name": true,
              "device_id": true,
              "entity_id": true,
              "entity_owner_id": true,
              "fleet_id": true,
              "fleet_name": true,
              "realm_id": true,
              "realm_name": true,
              "collector_name": true,
              "otel_scope_name": true,
              "otel_scope_version": true,
              "resource_type": true,
              "device_os": true,
              "device_type": true,
              "device_vers": true,
              "created": true
            },
            "renameByName": {
              "fb": "FlashBlade",
              "severity": "Severity",
              "summary": "Summary",
              "component_name": "Component",
              "component_type": "Type",
              "kburl": "KB URL",
              "action": "Action"
            }
          }
        }
      ],
      "options": {
        "showHeader": true,
        "cellHeight": "sm"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "filterable": true
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Severity"
            },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background"
                }
              },
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "critical": {
                        "color": "red"
                      },
                      "warning": {
                        "color": "yellow"
                      },
                      "info": {
                        "color": "blue"
                      }
                    }
                  }
                ]
              }
            ]
          }
        ]
      }
    },
    {
      "id": 4,
      "type": "piechart",
      "title": "Space by Type (sum across selected FBs)",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 11
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (space) (purefb_array_space_bytes{space=~\"unique|snapshots|shared|virtual\", instance=~\"$fb\"})",
          "legendFormat": "OM \u00b7 {{space}}",
          "instant": true
        },
        {
          "refId": "B",
          "expr": "sum by (space_type) (last_over_time(flashblade_storage_device_space_bytes{space_type=~\"unique|snapshots|shared|virtual\", exported_storage_type=\"all\", device_name=~\"$fb\"}[10m]))",
          "legendFormat": "OTel \u00b7 {{space_type}}",
          "instant": true
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "values": [
            "value",
            "percent"
          ]
        },
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        }
      }
    },
    {
      "id": 5,
      "type": "piechart",
      "title": "IOPS by IO Type",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 0,
        "y": 19
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (dimension) (avg_over_time(purefb_array_performance_throughput_iops{instance=~\"$fb\", protocol=\"all\"}[$__range]))",
          "legendFormat": "OM \u00b7 {{dimension}}",
          "instant": true
        },
        {
          "refId": "B",
          "expr": "sum by (op) (avg_over_time(flashblade_storage_device_iops{device_name=~\"$fb\", proto=\"all\", op=~\"read|write\"}[$__range]))",
          "legendFormat": "OTel \u00b7 {{op}}",
          "instant": true
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "values": [
            "value"
          ]
        },
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "iops"
        }
      }
    },
    {
      "id": 6,
      "type": "piechart",
      "title": "IOPS by Protocol",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 8,
        "y": 19
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (protocol) (avg_over_time(purefb_array_performance_throughput_iops{instance=~\"$fb\", protocol=~\"NFS|SMB|S3|HTTP\"}[$__range]))",
          "legendFormat": "OM \u00b7 {{protocol}}",
          "instant": true
        },
        {
          "refId": "B",
          "expr": "sum by (proto) (avg_over_time(flashblade_storage_device_iops{device_name=~\"$fb\", proto=~\"nfs|smb|s3|http\", op=~\"read|write\"}[$__range]))",
          "legendFormat": "OTel \u00b7 {{proto}}",
          "instant": true
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "values": [
            "value"
          ]
        },
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "iops"
        }
      }
    },
    {
