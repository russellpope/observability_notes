      },
      "targets": [
        {
          "refId": "A",
          "expr": "topk($TopItems, avg by (instance, name, dimension) (purefb_file_systems_performance_latency_usec{instance=~\"$fb\"}))",
          "legendFormat": "OM \u00b7 {{name}} @ {{instance}} / {{dimension}}"
        },
        {
          "refId": "B",
          "expr": "topk($TopItems, avg by (device_name, entity_name, op) (flashblade_storage_device_fs_latency_us{device_name=~\"$fb\", op=~\"read|write\"}))",
          "legendFormat": "OTel \u00b7 {{entity_name}} @ {{device_name}} / {{op}}"
        }
      ],
      "fieldConfig": {
