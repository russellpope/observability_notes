          "expr": "sum by (instance, protocol) (purefb_array_performance_throughput_iops{instance=~\"$fb\", protocol=~\"$protocol\"})",
          "legendFormat": "OM \u00b7 {{instance}} / {{protocol}}"
        },
        {
          "refId": "B",
          "expr": "sum by (device_name, proto) (flashblade_storage_device_iops{device_name=~\"$fb\", proto=~\"$protocol\", op=~\"read|write\"})",
