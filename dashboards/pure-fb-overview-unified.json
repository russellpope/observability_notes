        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 16,
        "y": 19
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (exported_storage_type) (last_over_time(flashblade_storage_device_space_bytes{space_type=\"total_physical\", exported_storage_type=~\"file|object\", device_name=~\"$fb\"}[10m]))",
