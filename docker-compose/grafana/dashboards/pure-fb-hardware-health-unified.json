        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "Value": true,
              "instance": true,
              "device_name": true,
              "device_id": true,
              "job": true,
              "namespace": true,
              "storage_type": true,
              "source": true,
              "env": true,
              "array_name": true,
              "os": true,
              "version": true,
              "system_id": true,
              "subscription_type": true,
              "collector_name": true,
              "otel_scope_name": true,
              "otel_scope_version": true,
              "fleet_id": true,
              "fleet_name": true,
              "realm_id": true,
              "realm_name": true,
              "resource_type": true,
              "device_os": true,
              "device_type": true,
              "device_vers": true,
              "created": true,
              "entity_id": true,
              "entity_name": true,
              "entity_owner": true,
              "entity_owner_id": true
            },
            "renameByName": {
              "fb": "FlashBlade",
              "ver": "Firmware"
            }
          }
        }
      ],
      "options": {
        "showHeader": true,
        "cellHeight": "sm"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto"
          }
        }
      }
