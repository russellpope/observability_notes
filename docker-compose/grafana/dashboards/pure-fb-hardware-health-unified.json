{
  "title": "Pure Storage FlashBlade - Hardware Health (Unified)",
  "uid": "fb-hardware-health-unified",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "tags": [
    "pure",
    "flashblade",
    "hardware",
    "health",
    "unified",
    "otel"
  ],
  "templating": {
    "list": [
      {
        "name": "fb",
        "label": "FlashBlade",
        "type": "query",
        "datasource": "Prometheus",
        "query": {
          "query": "query_result(label_replace(purefb_info, \"fb\", \"$1\", \"instance\", \"(.+)\") or label_replace(last_over_time(flashblade_storage_device_health[10m]), \"fb\", \"$1\", \"device_name\", \"(.+)\"))",
          "refId": "StandardVariableQuery"
        },
        "refresh": 1,
        "includeAll": true,
        "allValue": ".+",
        "multi": true,
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "regex": ".*fb=\"([^\"]+)\".*"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "text",
      "gridPos": {
        "h": 3,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "options": {
        "mode": "markdown",
        "content": "## Hardware Health \u2014 Unified\n\nPer-component-type health across all selected FBs. **Healthy** = OM value `1` or OTel value `5`. Anything else counts as unhealthy and colors red. Row below breaks down per component type (chassis, flash blades, bays, fabric modules, Ethernet ports, fans, power supplies)."
      },
      "transparent": true
    },
    {
      "id": 10,
      "type": "stat",
      "title": "Total Components",
      "datasource": "Prometheus",
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 0,
        "y": 3
      },
      "targets": [
        {
          "refId": "A",
          "instant": true,
          "expr": "count(purefb_hardware_health{instance=~\"$fb\"}) or count(last_over_time(flashblade_storage_device_health{device_name=~\"$fb\"}[10m]))",
          "legendFormat": "total"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "none",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0
        }
      }
    },
    {
      "id": 11,
      "type": "stat",
      "title": "Unhealthy Components",
      "datasource": "Prometheus",
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 6,
        "y": 3
      },
      "targets": [
        {
          "refId": "A",
          "instant": true,
          "expr": "(count(purefb_hardware_health{instance=~\"$fb\"} != 1) or vector(0)) + (count(last_over_time(flashblade_storage_device_health{device_name=~\"$fb\"}[10m]) != 5) or vector(0))",
          "legendFormat": "unhealthy"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "0",
                  "color": "green"
                }
              }
            }
          ]
        }
      }
    },
    {
      "id": 12,
      "type": "stat",
      "title": "Open Alerts",
      "datasource": "Prometheus",
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 12,
        "y": 3
      },
      "targets": [
        {
          "refId": "A",
          "instant": true,
          "expr": "count(purefb_alerts_open{instance=~\"$fb\"}) or count(last_over_time(flashblade_storage_device_alerts{device_name=~\"$fb\"}[10m]))",
          "legendFormat": "alerts"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          }
        }
      }
    },
    {
      "id": 13,
      "type": "table",
      "title": "Firmware Versions",
      "datasource": "Prometheus",
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 18,
