        "x": 0,
        "y": 11
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (space) (purefb_file_systems_space_bytes{instance=~\"$fb\", name=~\"$filesystem\", space=~\"total_physical|virtual|snapshots|unique\"})",
          "legendFormat": "{{space}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 25,
            "stacking": {
              "mode": "normal"
            }
          }
        }
      }
    },
