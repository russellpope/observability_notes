          "expr": "sum(purefb_file_systems_space_bytes{instance=~\"$fb\", name=~\"$filesystem\", space=\"snapshots\"}) or sum(last_over_time(flashblade_storage_device_fs_space_bytes{device_name=~\"$fb\", entity_name=~\"$filesystem\", space_type=\"snapshots\"}[10m]))",
