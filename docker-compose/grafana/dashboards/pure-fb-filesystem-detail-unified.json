      "targets": [
        {
          "refId": "A",
          "instant": true,
          "expr": "avg(purefb_file_systems_space_data_reduction_ratio{instance=~\"$fb\", name=~\"$filesystem\"}) or avg(last_over_time(flashblade_storage_device_fs_space_reduction{device_name=~\"$fb\", entity_name=~\"$filesystem\"}[10m]))",
          "legendFormat": "drr"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
