      "targets": [
        {
          "refId": "A",
          "expr": "sum by (instance, name, dimension) (purefb_file_systems_performance_throughput_iops{instance=~\"$fb\", name=~\"$filesystem\"})",
          "legendFormat": "OM \u00b7 {{name}} @ {{instance}} / {{dimension}}"
        },
        {
          "refId": "B",
          "expr": "sum by (device_name, entity_name, op) (flashblade_storage_device_fs_iops{device_name=~\"$fb\", entity_name=~\"$filesystem\", op=~\"read|write\"})",
          "legendFormat": "OTel \u00b7 {{entity_name}} @ {{device_name}} / {{op}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "iops"
        }
      }
    },
