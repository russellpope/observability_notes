            }
          }
        }
      }
    },
    {
      "id": 40,
      "type": "row",
      "title": "Filesystem performance time series",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 19
      },
      "collapsed": false
    },
    {
      "id": 41,
      "type": "timeseries",
      "title": "File System IOPS",
      "datasource": "Prometheus",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
